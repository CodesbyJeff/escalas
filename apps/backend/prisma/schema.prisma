generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ESCALANTE
  MILITAR
  GESTOR
  FISCAL
}

model User {
  id                 Int               @id @default(autoincrement())
  cpf                String            @unique
  matricula          String?           @unique
  nome               String
  nome_curto         String?
  email              String?           @unique
  phone              String?
  posto              String?
  sisbom_id          String?           @unique
  sisbom_lotacao_ref String?
  ativo              Boolean           @default(true)
  is_super_admin     Boolean           @default(false)
  senha_hash         String? // bcrypt; NULL = autentica via SISBOM AD
  last_sync_at       DateTime
  lotacoes           UserLotacao[]
  roles              UserRole[]
  templates_criados  TemplateLotacao[]
  escalas_criadas    Escala[]          @relation("EscalaCriador")
  vagas              Vaga[]            @relation("VagaMilitar")
  versoes_publicadas EscalaVersao[]    @relation("VersaoPublicador")
  audit_logs         AuditLog[]
  validacoes_feitas  ValidacaoEscala[] @relation("ValidacaoGestor")
  execucoes_militar  ExecucaoVaga[]    @relation("ExecucaoMilitar")
  dias_fiscalizados  EscalaDia[]       @relation("EscalaDiaFiscal")
  dias_validados     EscalaDia[]       @relation("EscalaDiaValidador")
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
}

model Lotacao {
  id             Int               @id @default(autoincrement())
  sisbom_id      String?           @unique
  sisbom_ref     String?           @unique
  sigla          String
  sigla_extenso  String?
  nome           String
  lotacao_pai_id Int?
  nivel          Int
  operacional    Boolean           @default(false)
  externo        Boolean           @default(false)
  last_sync_at   DateTime?
  pai            Lotacao?          @relation("LotacaoHierarquia", fields: [lotacao_pai_id], references: [id])
  filhas         Lotacao[]         @relation("LotacaoHierarquia")
  user_lotacoes  UserLotacao[]
  user_roles     UserRole[]
  templates      TemplateLotacao[]
  escalas        Escala[]
}

model UserLotacao {
  user_id    Int
  lotacao_id Int
  nivel      Int
  user       User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lotacao    Lotacao @relation(fields: [lotacao_id], references: [id])

  @@id([user_id, lotacao_id])
}

model UserRole {
  id         Int      @id @default(autoincrement())
  user_id    Int
  role       Role
  lotacao_id Int?
  created_by Int
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lotacao    Lotacao? @relation(fields: [lotacao_id], references: [id])

  @@unique([user_id, role, lotacao_id])
}

model SyncCursor {
  entidade           String   @id
  last_sync_at       DateTime
  last_mirror_ref_at DateTime
}

model TemplateLotacao {
  id            Int      @id @default(autoincrement())
  lotacao_id    Int
  nome          String
  criado_por_id Int
  updated_at    DateTime @updatedAt

  lotacao    Lotacao             @relation(fields: [lotacao_id], references: [id])
  criado_por User                @relation(fields: [criado_por_id], references: [id])
  guarnicoes TemplateGuarnicao[]
  escalas    Escala[]

  @@unique([lotacao_id, nome])
  @@index([criado_por_id])
}

model TemplateGuarnicao {
  id                  Int    @id @default(autoincrement())
  template_lotacao_id Int
  sigla               String
  atividade           String
  turno_padrao_inicio String
  turno_padrao_fim    String
  ordem               Int

  template        TemplateLotacao        @relation(fields: [template_lotacao_id], references: [id], onDelete: Cascade)
  vagas_sugeridas TemplateVagaSugerida[]

  @@index([template_lotacao_id])
}

model TemplateVagaSugerida {
  id                    Int    @id @default(autoincrement())
  template_guarnicao_id Int
  funcao                String
  quantidade_sugerida   Int

  guarnicao TemplateGuarnicao @relation(fields: [template_guarnicao_id], references: [id], onDelete: Cascade)

  @@index([template_guarnicao_id])
}

enum EscalaStatus {
  rascunho
  publicada
  em_validacao
  aprovada
  rejeitada
}

model Escala {
  id            Int          @id @default(autoincrement())
  lotacao_id    Int
  mes           Int
  ano           Int
  status        EscalaStatus @default(rascunho)
  criado_por_id Int
  template_id   Int?
  publicado_em  DateTime?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  lotacao    Lotacao              @relation(fields: [lotacao_id], references: [id])
  criado_por User                 @relation("EscalaCriador", fields: [criado_por_id], references: [id])
  template   TemplateLotacao?     @relation(fields: [template_id], references: [id], onDelete: SetNull)
  dias       EscalaDia[]
  versoes    EscalaVersao[]
  validacoes ValidacaoEscala[]

  @@unique([lotacao_id, mes, ano])
  @@index([criado_por_id])
  @@index([template_id])
}

model EscalaDia {
  id              Int            @id @default(autoincrement())
  escala_id       Int
  data            DateTime
  observacoes     String?
  execucao_status ExecucaoStatus @default(pendente)
  fiscal_id       Int?
  validado_por_id Int?
  validado_em     DateTime?
  justificativa   String?

  escala       Escala            @relation(fields: [escala_id], references: [id], onDelete: Cascade)
  guarnicoes   EscalaGuarnicao[]
  fiscal       User?             @relation("EscalaDiaFiscal", fields: [fiscal_id], references: [id])
  validado_por User?             @relation("EscalaDiaValidador", fields: [validado_por_id], references: [id])

  @@unique([escala_id, data])
}

model EscalaGuarnicao {
  id            Int     @id @default(autoincrement())
  escala_dia_id Int
  sigla         String
  atividade     String
  viatura_id    String?
  turno_inicio  String
  turno_fim     String
  ordem         Int

  dia   EscalaDia @relation(fields: [escala_dia_id], references: [id], onDelete: Cascade)
  vagas Vaga[]

  @@index([escala_dia_id])
}

model Vaga {
  id                  Int     @id @default(autoincrement())
  escala_guarnicao_id Int
  funcao              String
  militar_id          Int?
  turno_inicio        String
  turno_fim           String
  observacoes         String?

  guarnicao EscalaGuarnicao @relation(fields: [escala_guarnicao_id], references: [id], onDelete: Cascade)
  militar   User?           @relation("VagaMilitar", fields: [militar_id], references: [id])
  execucao  ExecucaoVaga?

  @@index([escala_guarnicao_id])
  @@index([militar_id])
}

model EscalaVersao {
  id               Int      @id @default(autoincrement())
  escala_id        Int
  versao           Int
  publicado_por_id Int
  publicado_em     DateTime @default(now())
  conteudo         Json

  escala        Escala            @relation(fields: [escala_id], references: [id], onDelete: Cascade)
  publicado_por User              @relation("VersaoPublicador", fields: [publicado_por_id], references: [id])
  validacoes    ValidacaoEscala[]

  @@unique([escala_id, versao])
}

model AuditLog {
  id             Int      @id @default(autoincrement())
  user_id        Int?
  acao           String
  entidade       String
  entidade_id    Int
  payload_antes  Json?
  payload_depois Json?
  created_at     DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([entidade, entidade_id])
  @@index([user_id, created_at])
}

enum ValidacaoStatus {
  aprovada
  rejeitada
}

model ValidacaoEscala {
  id                  Int             @id @default(autoincrement())
  escala_id           Int
  escala_versao_id    Int
  gestor_id           Int
  status              ValidacaoStatus
  justificativa       String?
  mapa_forca_snapshot Json
  created_at          DateTime        @default(now())

  escala        Escala       @relation(fields: [escala_id], references: [id], onDelete: Cascade)
  escala_versao EscalaVersao @relation(fields: [escala_versao_id], references: [id], onDelete: Restrict)
  gestor        User         @relation("ValidacaoGestor", fields: [gestor_id], references: [id], onDelete: Restrict)

  @@index([escala_id])
  @@index([gestor_id])
}

enum FeriadoTipo {
  nacional // raramente cadastrado (nacionais são calculados no util feriadosBrasil); permitido p/ casos ad-hoc
  estadual
  municipal
  facultativo
}

// Feriados cadastrados manualmente (estaduais/municipais/facultativos). Global,
// sem vínculo de lotação — igual ao ServicoFeriado do SISBOM. Usado apenas para
// classificar serviços como fim_de_semana_feriado na contagem do mapa de força;
// não altera o número de vagas. Feriados nacionais virão de um util, não da tabela.
model Feriado {
  id         Int         @id @default(autoincrement())
  data       DateTime    @unique
  descricao  String
  tipo       FeriadoTipo @default(estadual)
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
}

enum ExecucaoStatus {
  pendente
  registrada
  validada
  rejeitada
}

enum SituacaoExecucao {
  presente
  falta
  substituido
  preenchido
}

model ExecucaoVaga {
  id                   Int              @id @default(autoincrement())
  vaga_id              Int              @unique
  vaga                 Vaga             @relation(fields: [vaga_id], references: [id], onDelete: Cascade)
  situacao             SituacaoExecucao
  militar_executado_id Int?
  militar_executado    User?            @relation("ExecucaoMilitar", fields: [militar_executado_id], references: [id])
  do                   Boolean          @default(false)
  observacoes          String?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
}
