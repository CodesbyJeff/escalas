NODE_ENV=development
API_PORT=3000

DATABASE_URL=postgresql://escalas:escalas@localhost:5432/escalas_dev?schema=public
POSTGRES_USER=escalas
POSTGRES_PASSWORD=escalas
POSTGRES_DB=escalas_dev

JWT_SECRET=change-me-in-prod-with-16-chars-minimum
JWT_REFRESH_SECRET=change-me-too-with-16-chars-minimum
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Admin local (bypassa SISBOM AD; opcional — se omitido, seeder não cria conta)
ADMIN_LOCAL_CPF=99999999900
ADMIN_LOCAL_NOME=Admin Operacional Escalas
ADMIN_LOCAL_PASSWORD=troque-isso-em-dev-min-8-chars

SISBOM_AUTH_URL=https://api.sisbom.cbm.rn.gov.br/api/login-ad
# Endpoints /external do api_sisbom (montados na raiz da function, sem /api/v1).
# Ajustar para o domínio público real do api_sisbom em produção.
SISBOM_EXTERNAL_BASE_URL=https://us-central1-cfap-app.cloudfunctions.net/api_sisbom/external
# Deve casar com a env ESCALAS_API_KEY configurada no servidor do SISBOM.
SISBOM_API_KEY=request-from-tenente-peter
SYNC_INTERVAL_CRON=*/5 * * * *

DATABASE_URL_TEST=postgresql://escalas:escalas@localhost:5432/escalas_test?schema=public
